# Copy relevant values into application.properties or set as environment variables.

# SQL Server
spring.datasource.url=jdbc:sqlserver://localhost:1433;databaseName=givinghands_db;encrypt=false
spring.datasource.username=sa
spring.datasource.password=YOUR_DB_PASSWORD

# Schema: run database/fix-schema.sql before first start (ddl-auto=none)

# Gmail SMTP (required for automatic notification emails)
# 1. Enable 2-Step Verification on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Set environment variables before starting Spring Boot:
#
#    Windows PowerShell:
#      $env:MAIL_USERNAME="your.real.email@gmail.com"
#      $env:MAIL_PASSWORD="your-16-char-app-password"
#
#    Windows CMD:
#      set MAIL_USERNAME=your.real.email@gmail.com
#      set MAIL_PASSWORD=your-16-char-app-password
#
spring.mail.username=${MAIL_USERNAME:}
spring.mail.password=${MAIL_PASSWORD:}
givinghands.mail.enabled=true
