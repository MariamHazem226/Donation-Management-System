* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  /* New Professional Color Palette */
  --primary: #4CAF50;        /* Green - trust + impact */
  --primary-dark: #388E3C;    /* Darker green for hover */
  --primary-light: #81C784;   /* Light green for accents */
  --primary-bg: #E8F5E9;      /* Very light green background */
  
  --secondary: #1E3A8A;       /* Dark Blue - credibility */
  --secondary-dark: #152C6B;  /* Darker blue */
  --secondary-light: #3B5DB0; /* Light blue */
  --secondary-bg: #E8EDF5;    /* Very light blue background */
  
  --cta: #FF6B35;             /* Orange - strong action for donate */
  --cta-dark: #E55A2B;        /* Darker orange for hover */
  --cta-light: #FF8A5C;       /* Light orange for accents */
  
  --success: #4CAF50;         /* Success green */
  --warning: #FF6B35;         /* Warning orange */
  --danger: #EF4444;          /* Danger red */
  
  --gray-50: #F9FAFB;         /* Background - very light gray */
  --gray-100: #F3F4F6;
  --gray-200: #E5E7EB;
  --gray-300: #D1D5DB;
  --gray-400: #9CA3AF;
  --gray-500: #6B7280;
  --gray-600: #4B5563;
  --gray-700: #374151;
  --gray-800: #1F2937;        /* Text color */
  --gray-900: #111827;
  
  --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
  --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
  
  --radius-sm: 0.375rem;
  --radius-md: 0.5rem;
  --radius-lg: 0.75rem;
  --radius-xl: 1rem;
  --radius-2xl: 1.5rem;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--gray-50);
  color: var(--gray-800);
  line-height: 1.5;
}

/* Navigation */
.nav-main {
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--gray-200);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 1rem 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-brand {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 1.25rem;
  font-weight: 700;
}

.brand-text span {
  color: var(--primary);
}

.nav-menu {
  display: flex;
  gap: 2rem;
  align-items: center;
}

.nav-link {
  text-decoration: none;
  color: var(--gray-600);
  font-weight: 500;
  transition: color 0.2s;
}

.nav-link:hover, .nav-link.active {
  color: var(--primary);
}

.nav-actions {
  display: flex;
  gap: 1rem;
  align-items: center;
}

/* Buttons */
.btn-primary {
  background: var(--primary);
  color: white;
  padding: 0.625rem 1.25rem;
  border-radius: 9999px;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.2s;
  border: none;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.btn-primary:hover {
  background: var(--primary-dark);
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
}

/* CTA Button - Special Orange for Donate */
.btn-cta {
  background: var(--cta);
  color: white;
  padding: 0.625rem 1.25rem;
  border-radius: 9999px;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.2s;
  border: none;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.btn-cta:hover {
  background: var(--cta-dark);
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
}

.btn-secondary {
  background: transparent;
  color: var(--gray-700);
  padding: 0.625rem 1.25rem;
  border-radius: 9999px;
  text-decoration: none;
  font-weight: 500;
  border: 1px solid var(--gray-300);
  transition: all 0.2s;
}

.btn-secondary:hover {
  background: var(--gray-100);
  border-color: var(--primary);
  color: var(--primary);
}

.btn-primary-large {
  background: var(--primary);
  color: white;
  padding: 0.875rem 2rem;
  border-radius: 9999px;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
}

.btn-primary-large:hover {
  background: var(--primary-dark);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(76, 175, 80, 0.3);
}

.btn-outline-large {
  background: transparent;
  color: white;
  padding: 0.875rem 2rem;
  border-radius: 9999px;
  text-decoration: none;
  font-weight: 600;
  border: 2px solid rgba(255, 255, 255, 0.3);
  transition: all 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
}

.btn-outline-large:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: var(--primary);
}

/* Hero Section */
/* Hero Slider */
.hero-slider {
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.hero-slider .carousel {
  height: 100vh;
  min-height: 600px;
}

.hero-slide {
  height: 100vh;
  min-height: 600px;
  position: relative;
  display: flex;
  align-items: center;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.2);
  backdrop-filter: blur(2px);
  display: flex;
  align-items: center;
}

.hero-slider .carousel-indicators [data-bs-target] {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  border: 2px solid transparent;
  opacity: 0.6;
  transition: all 0.3s;
}

.hero-slider .carousel-indicators .active {
  background: var(--primary);
  opacity: 1;
  transform: scale(1.2);
}

.hero-slider .carousel-control-prev,
.hero-slider .carousel-control-next {
  width: 5%;
  opacity: 0.8;
  transition: opacity 0.3s;
}

.hero-slider .carousel-control-prev:hover,
.hero-slider .carousel-control-next:hover {
  opacity: 1;
}

.hero-slider .carousel-control-prev-icon,
.hero-slider .carousel-control-next-icon {
  background-size: 20px;
  background-position: center;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background-color: rgba(0,0,0,0.8);
  backdrop-filter: blur(10px);
  border: 2px solid rgba(255,255,255,0.3);
}

.carousel-fade .carousel-item {
  transition: opacity 1s ease-in-out;
}

/* Stats Impact Section */
.statistics {
  background: linear-gradient(135deg, #f8fafc 0%, #eef7f1 100%);
  padding: 4rem 1rem;
}

.statistics-container {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

/* Card */
.statistics-card {
  padding: 2.5rem 2rem;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  text-align: center;
}


/* Icon */
.stat-icon {
  width: 70px;
  height: 70px;
  margin: 0 auto 1rem;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 1.5rem;
  box-shadow: 0 10px 25px rgba(76,175,80,0.3);
}

/* Number */
.stat-number {
  font-size: 2.8rem;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 0.5rem;
}

/* Label */
.stat-label {
  font-size: 0.95rem;
  color: #6b7280;
  font-weight: 500;
  letter-spacing: 0.5px;
}

/* Scroll animation */
.animate-on-scroll {
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.6s ease;
}

.animate-on-scroll.animate {
  opacity: 1;
  transform: translateY(0);
}

/* Responsive */
@media (max-width: 900px) {
  .statistics-container {
    grid-template-columns: 1fr;
  }
}

/* Responsive */
@media (max-width: 768px) {
  .hero-slider .carousel {
    height: 70vh;
    min-height: 500px;
  }
  
  .hero-slide, .hero-overlay {
    height: 70vh;
    min-height: 500px;
  }
  
  .hero-headline {
    font-size: 2.25rem !important;
  }
  
  .hero-description {
    font-size: 1rem !important;
  }
  
  .btn-primary-large, .btn-outline-large {
    width: 100%;
    justify-content: center;
    margin-bottom: 1rem;
  }
  
  .hero-cta-group {
    flex-direction: column;
    align-items: stretch;
  }
  
  .stats-impact {
    padding: 3rem 1rem;
  }
  
  .stat-card {
    padding: 2rem 1rem;
  }
  
  .stat-number {
    font-size: 2.5rem;
  }
}

@media (max-width: 480px) {
  .hero-slider .carousel-control-prev-icon,
  .hero-slider .carousel-control-next-icon {
    width: 40px;
    height: 40px;
  }
}


.hero-background {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  opacity: 0.4;
}

.orb-1 {
  width: 300px;
  height: 300px;
  background: var(--primary);
  top: -100px;
  right: -100px;
}

.orb-2 {
  width: 400px;
  height: 400px;
  background: var(--cta);
  bottom: -150px;
  left: -150px;
}

.orb-3 {
  width: 200px;
  height: 200px;
  background: var(--primary-light);
  top: 50%;
  left: 50%;
}

.hero-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  position: relative;
  z-index: 2;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(8px);
  padding: 0.5rem 1rem;
  border-radius: 9999px;
  color: var(--gray-300);
  font-size: 0.875rem;
  margin-bottom: 1.5rem;
}

.badge-dot {
  width: 8px;
  height: 8px;
  background: var(--primary);
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.2); }
}

.hero-headline {
  font-size: 3.5rem;
  font-weight: 800;
  line-height: 1.2;
  color: white;
  margin-bottom: 1.5rem;
}

.gradient-text {
  background: linear-gradient(135deg, var(--primary), var(--cta));
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.hero-description {
  font-size: 1.125rem;
  color: var(--gray-300);
  margin-bottom: 2rem;
  line-height: 1.6;
}

.hero-cta-group {
  display: flex;
  gap: 1rem;
  margin-bottom: 2rem;
}

.hero-stats {
  display: flex;
  gap: 2rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 1.5rem;
  font-weight: 700;
  color: white;
}

.stat-label {
  font-size: 0.875rem;
  color: var(--gray-400);
}

.stat-divider {
  width: 1px;
  background: rgba(255, 255, 255, 0.2);
}

.impact-card {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12px);
  border-radius: var(--radius-2xl);
  padding: 1.5rem;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.impact-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: white;
  margin-bottom: 1.5rem;
}

.impact-stats {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.impact-stat {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 0.75rem 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.impact-number {
  font-size: 1.5rem;
  font-weight: 700;
  color: white;
}

.impact-desc {
  color: var(--gray-400);
  font-size: 0.875rem;
}

/* Filter Bar */
.filter-bar-wrapper {
  background: white;
  border-bottom: 1px solid var(--gray-200);
  position: sticky;
  top: 73px;
  z-index: 99;
}

.filter-container {
  display: flex;
  gap: 2rem;
  align-items: center;
  padding: 1.25rem 0;
  flex-wrap: wrap;
}

.search-field {
  flex: 1;
  position: relative;
  min-width: 250px;
}

.search-field i {
  position: absolute;
  left: 1rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--gray-400);
}

.search-field input {
  width: 100%;
  padding: 0.75rem 1rem 0.75rem 2.5rem;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  font-size: 0.875rem;
  transition: all 0.2s;
}

.search-field input:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(76, 175, 80, 0.1);
}

.filter-group {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.filter-chip {
  padding: 0.5rem 1rem;
  border-radius: 9999px;
  border: 1px solid var(--gray-200);
  background: white;
  cursor: pointer;
  font-size: 0.875rem;
  font-weight: 500;
  transition: all 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.filter-chip:hover {
  border-color: var(--primary);
  color: var(--primary);
}

.filter-chip.active {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

/* Campaigns Grid */
.campaigns-section {
  padding: 3rem 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 2rem;
}

.section-header h2 {
  font-size: 1.875rem;
  font-weight: 700;
  color: var(--gray-800);
  margin-bottom: 0.5rem;
}

.section-header p {
  color: var(--gray-500);
}



/* Bootstrap grid now handles layout - custom grid removed */

.campaign-card-modern {
  background: #FFFFFF;  /* White cards */
  border-radius: var(--radius-xl);
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  border: 1px solid var(--gray-200);
}

.campaign-card-modern:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-xl);
  border-color: var(--gray-300);
}

.campaign-image {
  height: 220px;
  background-size: cover;
  background-position: center;
  position: relative;
}

.campaign-category {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(4px);
  padding: 0.25rem 0.75rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 600;
  color: white;
}

.campaign-content {
  padding: 1.5rem;
}

.campaign-title {
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  color: var(--gray-800);
}

.campaign-description {
  color: var(--gray-500);
  font-size: 0.875rem;
  margin-bottom: 1rem;
  line-height: 1.5;
}

.progress-section {
  margin: 1rem 0;
}

.progress-bar {
  background: var(--gray-200);
  border-radius: 9999px;
  height: 8px;
  overflow: hidden;
}

.progress-fill {
  background: linear-gradient(90deg, var(--primary), var(--cta));
  height: 100%;
  width: 0%;
  transition: width 1s ease-out;
  border-radius: 9999px;
}

.progress-stats {
  display: flex;
  justify-content: space-between;
  margin-top: 0.5rem;
  font-size: 0.875rem;
  font-weight: 500;
}

.raised {
  color: var(--primary);
}

.goal {
  color: var(--gray-500);
}

.campaign-meta {
  display: flex;
  justify-content: space-between;
  margin: 1rem 0;
  padding: 0.75rem 0;
  border-top: 1px solid var(--gray-100);
  border-bottom: 1px solid var(--gray-100);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.875rem;
  color: var(--gray-600);
}

.campaign-actions-modern {
  display: flex;
  gap: 0.75rem;
  margin-top: 1rem;
}

.btn-sm {
  padding: 0.5rem 1rem;
  font-size: 0.875rem;
}

/* Dashboard Styles */
.dashboard-body {
  background: var(--gray-50);
  overflow-x: hidden;
}

.dashboard-layout {
  display: flex;
  min-height: 100vh;
}

.dashboard-sidebar {
  width: 280px;
  background: white;
  border-right: 1px solid var(--gray-200);
  display: flex;
  flex-direction: column;
  position: fixed;
  height: 100vh;
  overflow-y: auto;
}

.sidebar-header {
  padding: 1.5rem;
  border-bottom: 1px solid var(--gray-200);
}

.logo-mini {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-weight: 700;
  font-size: 1.125rem;
}

.logo-mini span {
  color: var(--primary);
}

.sidebar-nav {
  flex: 1;
  padding: 1.5rem 0;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1.5rem;
  text-decoration: none;
  color: var(--gray-600);
  transition: all 0.2s;
  position: relative;
}

.nav-item:hover {
  background: var(--gray-50);
  color: var(--primary);
}

.nav-item.active {
  background: linear-gradient(90deg, rgba(76, 175, 80, 0.1) 0%, transparent 100%);
  color: var(--primary);
  border-left: 3px solid var(--primary);
}

.nav-item .badge {
  margin-left: auto;
  background: var(--primary);
  color: white;
  padding: 0.125rem 0.5rem;
  border-radius: 9999px;
  font-size: 0.625rem;
}

.sidebar-footer {
  padding: 1rem 0;
  border-top: 1px solid var(--gray-200);
}

.dashboard-main {
  flex: 1;
  margin-left: 280px;
  padding: 2rem;
}

.dashboard-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
}

.header-left h1 {
  font-size: 1.875rem;
  font-weight: 700;
  margin-bottom: 0.25rem;
}

.header-left p {
  color: var(--gray-500);
}

.header-right {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.notification-bell {
  position: relative;
  cursor: pointer;
}

.notification-dot {
  position: absolute;
  top: -2px;
  right: -2px;
  width: 8px;
  height: 8px;
  background: var(--cta);
  border-radius: 50%;
}

.user-profile {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.user-profile img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  object-fit: cover;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-weight: 600;
  font-size: 0.875rem;
}

.user-role {
  font-size: 0.75rem;
  color: var(--gray-500);
}

/* Stats Cards */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.stat-card {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--gray-200);
  transition: all 0.2s;
}

.stat-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.stat-icon {
  width: 56px;
  height: 56px;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
}

.stat-icon.blue {
  background: rgba(76, 175, 80, 0.1);
  color: var(--primary);
}

.stat-icon.green {
  background: rgba(76, 175, 80, 0.1);
  color: var(--primary);
}

.stat-icon.purple {
  background: rgba(30, 58, 138, 0.1);
  color: var(--secondary);
}

.stat-icon.orange {
  background: rgba(255, 107, 53, 0.1);
  color: var(--cta);
}

.stat-details {
  flex: 1;
}

.stat-label {
  font-size: 0.875rem;
  color: var(--gray-500);
  display: block;
}

.stat-value {
  font-size: 1.875rem;
  font-weight: 700;
  color: var(--gray-800);
  display: block;
}

.stat-trend {
  font-size: 0.75rem;
  margin-top: 0.25rem;
  display: inline-block;
}

.stat-trend.positive {
  color: var(--primary);
}

.stat-trend.neutral {
  color: var(--gray-500);
}

/* Charts & Tables */
.dashboard-charts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.chart-card {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  border: 1px solid var(--gray-200);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

.chart-header h3 {
  font-size: 1rem;
  font-weight: 600;
}

.chart-select {
  padding: 0.375rem 0.75rem;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-md);
  font-size: 0.875rem;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  gap: 1rem;
  height: 200px;
  padding-top: 1rem;
}

.bar-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.bar {
  width: 100%;
  background: linear-gradient(180deg, var(--primary), var(--cta));
  border-radius: var(--radius-sm);
  transition: height 0.5s ease;
  min-height: 4px;
}

.bar-label {
  font-size: 0.75rem;
  color: var(--gray-500);
}

.top-campaigns-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.top-campaign-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--gray-100);
}

.campaign-info h4 {
  font-size: 0.875rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.campaign-info span {
  font-size: 0.75rem;
  color: var(--gray-500);
}

.campaign-amount {
  font-weight: 600;
  color: var(--primary);
}

.table-container {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  border: 1px solid var(--gray-200);
}

.table-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
  gap: 1rem;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
}

.data-table th {
  text-align: left;
  padding: 0.75rem 1rem;
  background: var(--gray-50);
  font-weight: 600;
  font-size: 0.875rem;
  color: var(--gray-600);
}

.data-table td {
  padding: 1rem;
  border-bottom: 1px solid var(--gray-100);
  font-size: 0.875rem;
}

.data-table tr:hover {
  background: var(--gray-50);
}

.status-badge {
  display: inline-block;
  padding: 0.25rem 0.5rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 500;
}

.status-badge.approved {
  background: rgba(76, 175, 80, 0.1);
  color: var(--primary);
}

.status-badge.pending {
  background: rgba(255, 107, 53, 0.1);
  color: var(--cta);
}

.action-buttons {
  display: flex;
  gap: 0.5rem;
}

.action-btn {
  padding: 0.25rem 0.5rem;
  border-radius: var(--radius-md);
  border: none;
  cursor: pointer;
  font-size: 0.75rem;
}

/* Auth Pages */
.auth-page {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-dark) 100%);
  min-height: 100vh;
}

.auth-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 100vh;
}

.auth-left {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-dark) 100%);
  padding: 3rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: white;
}

.auth-brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 1.25rem;
  font-weight: 700;
}

.auth-brand span {
  color: var(--primary);
}

.auth-testimonial {
  max-width: 400px;
  margin: 0 auto;
}

.auth-testimonial i {
  font-size: 2rem;
  opacity: 0.5;
  margin-bottom: 1rem;
}

.auth-testimonial p {
  font-size: 1.25rem;
  line-height: 1.5;
  margin-bottom: 1.5rem;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.testimonial-author img {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
}

.testimonial-author strong {
  display: block;
  font-size: 0.875rem;
}

.testimonial-author span {
  font-size: 0.75rem;
  opacity: 0.7;
}

.auth-stats {
  display: flex;
  justify-content: center;
  gap: 2rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.auth-stats .stat {
  text-align: center;
}

.auth-stats .number {
  display: block;
  font-size: 1.5rem;
  font-weight: 700;
}

.auth-stats .label {
  font-size: 0.75rem;
  opacity: 0.7;
}

.auth-right {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  background: #FFFFFF;
}

.auth-card {
  max-width: 480px;
  width: 100%;
}

.auth-header {
  text-align: center;
  margin-bottom: 2rem;
}

.auth-header h2 {
  font-size: 1.875rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.auth-header p {
  color: var(--gray-500);
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.form-field label {
  font-weight: 500;
  font-size: 0.875rem;
}

.input-icon {
  position: relative;
}

.input-icon i:first-child {
  position: absolute;
  left: 1rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--gray-400);
}

.input-icon input {
  width: 100%;
  padding: 0.75rem 1rem 0.75rem 2.5rem;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  font-size: 0.875rem;
  transition: all 0.2s;
}

.input-icon input:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(76, 175, 80, 0.1);
}

.toggle-password {
  position: absolute;
  right: 1rem;
  top: 50%;
  transform: translateY(-50%);
  cursor: pointer;
  color: var(--gray-400);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.form-field.half {
  flex: 1;
}

.role-selector {
  display: flex;
  gap: 1rem;
}

.role-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem;
  border: 2px solid var(--gray-200);
  border-radius: var(--radius-lg);
  cursor: pointer;
  transition: all 0.2s;
}

.role-option input {
  display: none;
}

.role-option:has(input:checked) {
  border-color: var(--primary);
  background: rgba(76, 175, 80, 0.05);
}

.role-option i {
  font-size: 1.5rem;
  color: var(--gray-500);
}

.role-option:has(input:checked) i {
  color: var(--primary);
}

.form-options {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.875rem;
}

.checkbox {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
}

.forgot-link {
  color: var(--primary);
  text-decoration: none;
}

.btn-auth-submit {
  background: var(--primary);
  color: white;
  padding: 0.875rem;
  border: none;
  border-radius: var(--radius-lg);
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-auth-submit:hover {
  background: var(--primary-dark);
}

.auth-divider {
  text-align: center;
  margin: 1.5rem 0;
  position: relative;
}

.auth-divider::before,
.auth-divider::after {
  content: '';
  position: absolute;
  top: 50%;
  width: calc(50% - 60px);
  height: 1px;
  background: var(--gray-200);
}

.auth-divider::before {
  left: 0;
}

.auth-divider::after {
  right: 0;
}

.auth-divider span {
  background: white;
  padding: 0 1rem;
  font-size: 0.875rem;
  color: var(--gray-500);
}

.social-auth {
  display: flex;
  gap: 1rem;
}

.social-btn {
  flex: 1;
  padding: 0.75rem;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  background: white;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  transition: all 0.2s;
}

.social-btn:hover {
  background: var(--gray-50);
  border-color: var(--primary);
}

.auth-footer {
  text-align: center;
  margin-top: 1.5rem;
  font-size: 0.875rem;
}

.auth-footer a {
  color: var(--primary);
  text-decoration: none;
  font-weight: 500;
}

/* Volunteer Page */
.volunteer-page-body {
  background: var(--gray-50);
}

.volunteer-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 2rem;
}

.volunteer-progress {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 3rem;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.step-number {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--gray-200);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  color: var(--gray-500);
}

.progress-step.active .step-number {
  background: var(--primary);
  color: white;
}

.progress-line {
  width: 100px;
  height: 2px;
  background: var(--gray-200);
  margin: 0 1rem;
}

.volunteer-grid {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 2rem;
}

.campaign-selector {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  border: 1px solid var(--gray-200);
}

.campaign-selector h3 {
  margin-bottom: 1rem;
}

.campaign-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.campaign-option {
  padding: 1rem;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  cursor: pointer;
  transition: all 0.2s;
}

.campaign-option:hover {
  border-color: var(--primary);
  background: rgba(76, 175, 80, 0.05);
}

.campaign-option.selected {
  border-color: var(--primary);
  background: rgba(76, 175, 80, 0.05);
}

.application-form {
  padding: 1.5rem;
}

.application-form h2 {
  margin-bottom: 1.5rem;
}

.form-group {
  margin-bottom: 1rem;
}

.form-group label {
  display: block;
  margin-bottom: 0.5rem;
  font-weight: 500;
  font-size: 0.875rem;
}

.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 0.75rem;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  font-size: 0.875rem;
  transition: all 0.2s;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(76, 175, 80, 0.1);
}

.btn-full {
  width: 100%;
  justify-content: center;
}

/* Modal */
.modal-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4px);
  z-index: 1000;
  align-items: center;
  justify-content: center;
}

.modal-container {
  background: #FFFFFF;
  border-radius: var(--radius-2xl);
  max-width: 500px;
  width: 90%;
  max-height: 90vh;
  overflow-y: auto;
  animation: modalSlideIn 0.3s ease;
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(-20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem;
  border-bottom: 1px solid var(--gray-200);
}

.modal-close {
  background: none;
  border: none;
  font-size: 1.5rem;
  cursor: pointer;
  color: var(--gray-400);
}

.modal-body {
  padding: 1.5rem;
}

.donation-amounts {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.amount-btn {
  padding: 0.75rem;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  background: white;
  cursor: pointer;
  font-weight: 500;
  transition: all 0.2s;
}

.amount-btn:hover {
  border-color: var(--primary);
  color: var(--primary);
}

.amount-btn:active {
  background: var(--primary);
  color: white;
}

.success-modal {
  text-align: center;
}

.success-icon {
  font-size: 4rem;
  color: var(--primary);
  margin-bottom: 1rem;
}

/* Toast */
.toast-container {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  z-index: 1100;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.toast {
  background: #FFFFFF;
  padding: 1rem 1.5rem;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  display: flex;
  align-items: center;
  gap: 0.75rem;
  animation: slideInRight 0.3s ease;
  border-left: 4px solid var(--primary);
}

.toast.success {
  border-left-color: var(--primary);
}

.toast.error {
  border-left-color: var(--cta);
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(100%);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* Newsletter */
.newsletter {
  padding: 4rem 0;
  background: var(--gray-100);
}

.newsletter-card {
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  border-radius: var(--radius-2xl);
  padding: 3rem;
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 2rem;
}

.newsletter-content h3 {
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
}

.newsletter-form {
  display: flex;
  gap: 0.5rem;
}

.newsletter-form input {
  padding: 0.75rem 1rem;
  border: none;
  border-radius: var(--radius-lg);
  width: 280px;
  font-size: 0.875rem;
}

.newsletter-form input:focus {
  outline: none;
  box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.3);
}

/* Footer */
.footer-minimal {
  background: var(--gray-900);
  color: var(--gray-400);
  padding: 2.5rem 0 1.5rem;
}

.footer-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
  gap: 1rem;
}

@media (max-width: 768px) {
  .footer-top {
    flex-direction: column;
    text-align: center;
  }
}

.footer-brand-simple {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 1.125rem;
  font-weight: 700;
  color: white;
}

.footer-links-simple {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
}

.footer-links-simple a {
  color: var(--gray-400);
  text-decoration: none;
  font-weight: 500;
  transition: color 0.2s ease;
}

.footer-links-simple a:hover {
  color: var(--primary);
}

.footer-bottom {
  text-align: center;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(255,255,255,0.1);
  font-size: 0.875rem;
  color: var(--gray-500);
}

/* Hide old footer styles if unused */
.footer-modern { display: none; }

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 2rem;
  margin-bottom: 2rem;
}

.footer-brand span {
  font-size: 1.25rem;
  font-weight: 700;
  color: white;
}

.footer-brand p {
  margin: 1rem 0;
  font-size: 0.875rem;
  line-height: 1.5;
}

.social-links {
  display: flex;
  gap: 1rem;
}

.social-links a {
  color: var(--gray-400);
  transition: color 0.2s;
}

.social-links a:hover {
  color: var(--primary);
}

.footer-links h4 {
  color: white;
  margin-bottom: 1rem;
  font-size: 0.875rem;
}

.footer-links a {
  display: block;
  color: var(--gray-400);
  text-decoration: none;
  font-size: 0.875rem;
  margin-bottom: 0.5rem;
  transition: color 0.2s;
}

.footer-links a:hover {
  color: var(--primary);
}

.footer-bottom {
  text-align: center;
  padding-top: 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  font-size: 0.875rem;
}

/* Responsive - Mobile First Foundation */
html {
  overflow-x: hidden;
  scroll-behavior: smooth;
}

@media (max-width: 640px) {
  /* Typography Scale */
  h1 { font-size: 1.75rem !important; line-height: 1.3 !important; }
  h2 { font-size: 1.5rem !important; }
  h3 { font-size: 1.25rem !important; }
  .hero-headline { font-size: 2rem !important; }
  .hero-description { font-size: 1rem !important; }
  
  /* Universal Spacing Reset */
  .container, .nav-container, .hero-container {
    padding-left: 1rem !important;
    padding-right: 1rem !important;
  }
  .nav-container { padding: 0.75rem 1rem !important; gap: 1rem; flex-direction: column; }
  .section-header, .profile-container { padding: 1.5rem 1rem; }
  
  /* Final Forms/Tables Polish */
  .table-container { 
    margin: -1rem; 
    border-radius: 0; 
    border: none; 
  }
  .data-table th, .data-table td { 
    padding: 0.75rem 0.5rem !important; 
    white-space: nowrap; 
  }
  .profile-tabs, .org-tabs { 
    overflow-x: auto; 
    padding-bottom: 0.5rem; 
  }
  .tab-btn { 
    white-space: nowrap; 
    flex-shrink: 0; 
  }
  
  /* Modal final touches */
  .modal-header { 
    padding: 1rem 1.5rem !important; 
  }
  .modal-body { 
    padding: 1.5rem !important; 
  }
  
  /* Progress steps */
  .volunteer-progress { 
    flex-wrap: wrap; 
    gap: 1rem; 
  }
  
  /* Perfect touch targets */
  * { 
    -webkit-tap-highlight-color: transparent; 
  }
  
  /* Mobile Navigation + Hamburger */
  .hamburger-btn {
    display: none;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--gray-700);
    padding: 0.5rem;
    z-index: 101;
  }
  @media (max-width: 640px) {
    .hamburger-btn { display: block !important; }
  }
  
  .nav-menu {
    display: none !important;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    flex-direction: column;
    gap: 0;
    padding: 1rem;
    box-shadow: var(--shadow-lg);
    border-top: 1px solid var(--gray-200);
    z-index: 99;
  }
  .nav-menu.active { display: flex !important; }
  .nav-menu .nav-link { 
    padding: 0.75rem 0; 
    border-bottom: 1px solid var(--gray-100); 
    text-align: center;
  }
  .nav-actions { 
    order: -1; 
    width: 100%; 
    justify-content: center; 
    margin-bottom: 1rem;
  }
  
  /* Mobile Sidebar Overlay */
  .dashboard-sidebar {
    position: fixed !important;
    left: 0 !important;
    width: 85vw !important;
    max-width: 320px;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .dashboard-sidebar.open {
    transform: translateX(0) !important;
  }
  
  #mobile-overlay {
    z-index: 198 !important;
  }
  
  /* Hero Section Mobile */
  .hero-container { 
    grid-template-columns: 1fr !important; 
    text-align: center !important; 
    gap: 2rem !important;
  }
  .gradient-orb { display: none !important; }
  .hero-stats { 
    flex-direction: column !important; 
    gap: 1rem !important; 
    align-items: center !important;
  }
  .hero-cta-group { 
    flex-direction: column !important; 
    align-items: center !important; 
    gap: 1rem !important;
  }
  .hero-badge { justify-content: center; }
  
  /* Grids -> Single Column */
  .campaigns-grid-modern,
  .stats-grid,
  .stats-grid-profile,
  .analytics-stats,
  .impact-grid,
  .supporters-grid { 
    grid-template-columns: 1fr !important; 
  }
  .campaign-card-modern,
  .stat-card,
  .stat-card-profile,
  .analytics-card { 
    margin-bottom: 1.5rem !important; 
  }
  
  /* Touch-Friendly Buttons */
  .btn, .btn-primary, .btn-secondary, .btn-cta, .filter-chip,
  .toggle-btn, .amount-btn, .tab-btn, .action-btn {
    min-height: 48px !important;
    padding: 0.75rem 1.5rem !important;
    font-size: 1rem !important;
  }
  
  /* Forms & Inputs */
  .form-row,
  .input-icon,
  .role-selector { grid-template-columns: 1fr !important; gap: 1rem !important; }
  input, select, textarea { 
    font-size: 1rem !important; 
    padding: 1rem !important; 
    min-height: 48px !important;
  }
  .newsletter-form { flex-direction: column !important; gap: 1rem !important; }
  .newsletter-form input { width: 100% !important; }
  
  /* Cards & Sections */
  .campaign-card-modern,
  .dashboard-sidebar,
  .profile-info-wrapper,
  .org-info-wrapper { flex-direction: column !important; align-items: center !important; }
  .profile-avatar-large img,
  .org-logo img { width: 120px !important; height: 120px !important; }
  
  /* Tables & Overflow */
  .data-table, .donations-table { font-size: 0.875rem !important; }
  .table-container { overflow-x: auto !important; }
  
  /* Modals & Toasts Mobile */
  .modal-container { 
    width: 95vw !important; 
    max-width: none !important; 
    height: 90vh !important; 
    margin: 1rem !important;
  }
  .toast-container { 
    bottom: 1rem !important; 
    right: 1rem !important; 
    left: 1rem !important; 
  }
  .toast { 
    padding: 1rem !important; 
    font-size: 0.95rem !important;
  }
  
  /* Filters & Chips */
  .filter-container,
  .campaigns-filters { 
    flex-direction: column !important; 
    gap: 1rem !important; 
  }
  .search-field { min-width: 100% !important; }
  
  /* Footer & Newsletter */
  .footer-grid { grid-template-columns: 1fr !important; }
  .newsletter-card { 
    flex-direction: column !important; 
    text-align: center !important; 
    padding: 2rem 1.5rem !important;
  }
  
  /* Profile/Org Specific */
  .profile-meta,
  .org-meta { 
    flex-wrap: wrap !important; 
    justify-content: center !important; 
    gap: 1rem !important;
  }
  .profile-actions,
  .org-actions { justify-content: center !important; }
  
  /* Safe areas for notched phones */
  body { padding-top: env(safe-area-inset-top); }
}

@media (min-width: 641px) and (max-width: 1024px) {
  /* Tablet Foundation (641px-1024px) */
  
  /* Navigation */
  .nav-container { padding: 1rem 1.5rem; }
  .nav-menu { gap: 1.5rem; }
  
  /* Hero */
  .hero-container { gap: 3rem; }
  .hero-headline { font-size: 2.75rem; }
  .hero-stats { gap: 1.5rem; }
  
  /* Grids */
  .campaigns-grid-modern { 
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); 
  }
  .stats-grid, .stats-grid-profile,
  .analytics-stats { 
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); 
  }
  .impact-grid { 
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); 
  }
  
  /* Dashboard */
  .dashboard-main { padding: 1.5rem; }
  
  /* Profile/Org */
  .profile-info-wrapper,
  .org-info-wrapper { gap: 1.5rem; padding: 0 1.5rem 2rem; }
  
  /* Forms */
  .auth-card { max-width: 420px; }
  .newsletter-form input { width: 240px; }
  
  /* Cards */
  .campaign-card-modern { 
    grid-column: span 1; 
  }
}

@media (max-width: 1024px) {
  .stats-strip {
    flex-direction: row !important;
    flex-wrap: nowrap;
    overflow-x: auto;
    padding: 1.5rem;
    gap: 0.75rem;
  }
  
  .stats-strip .stat-item {
    flex: 0 0 280px;
    min-width: 280px;
  }
}
  
  .hero-container {
    grid-template-columns: 1fr;
    text-align: center;
  }
  
  .hero-stats {
    justify-content: center;
  }
  
  .hero-cta-group {
    justify-content: center;
  }
  
  .dashboard-sidebar {
    transform: translateX(-100%);
    transition: transform 0.3s;
    z-index: 200;
  }
  
  .dashboard-sidebar.open {
    transform: translateX(0);
  }
  
  .dashboard-main {
    margin-left: 0;
  }
  
  .dashboard-charts {
    grid-template-columns: 1fr;
  }
  
  .footer-grid {
    grid-template-columns: 1fr;
  }
  
  .volunteer-grid {
    grid-template-columns: 1fr;
  }
  
  .auth-layout {
    grid-template-columns: 1fr;
  }
  
  .auth-left {
    display: none;
  }

@media (max-width: 768px) {
  .nav-container {
    flex-direction: column;
    gap: 1rem;
  }
  
  .nav-menu {
    flex-wrap: wrap;
    justify-content: center;
  }
  
  .hero-headline {
    font-size: 2rem;
  }
  
  .filter-container {
    flex-direction: column;
  }
  
  .campaigns-grid-modern {
    grid-template-columns: 1fr;
  }
  
  .stats-grid {
    grid-template-columns: 1fr;
  }
  
  .newsletter-card {
    flex-direction: column;
    text-align: center;
  }
  
  .newsletter-form {
    width: 100%;
  }
  
  .newsletter-form input {
    flex: 1;
  }
}

/* Dashboard Views */
.dashboard-view {
  display: none;
}

.dashboard-view.active {
  display: block;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* Skeleton Loading */
.skeleton-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
}

.skeleton-grid .skeleton-card {
  flex: 0 0 calc(33.333% - 1rem);
  max-width: calc(33.333% - 1rem);
  height: 400px;
}

@media (max-width: 992px) {
  .skeleton-grid .skeleton-card {
    flex: 0 0 calc(50% - 0.75rem);
    max-width: calc(50% - 0.75rem);
  }
}

@media (max-width: 768px) {
  .skeleton-grid .skeleton-card {
    flex: 0 0 100%;
    max-width: 100%;
  }
}

.skeleton-card {
  background: white;
  border-radius: var(--radius-xl);
  height: 400px;
  position: relative;
  overflow: hidden;
}

.skeleton-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(0,0,0,0.05), transparent);
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  100% {
    left: 100%;
  }
}

.detail-skeleton {
  height: 600px;
  background: white;
  border-radius: var(--radius-2xl);
  margin: 2rem;
}

/* Campaign Details Page */
.campaign-detail-page {
  max-width: 1280px;
  margin: 0 auto;
  padding: 2rem;
}

.campaign-detail-card {
  background: #FFFFFF;
  border-radius: var(--radius-2xl);
  overflow: hidden;
}

.detail-hero {
  height: 500px;
  background-size: cover;
  background-position: center;
  position: relative;
}

.detail-hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 2rem;
  background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
  color: white;
}

.detail-content {
  padding: 2rem;
}

.creator-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem;
  background: var(--gray-50);
  border-radius: var(--radius-lg);
  margin: 1rem 0;
}

.volunteer-avatars {
  display: flex;
  align-items: center;
  margin: 1rem 0;
}

.volunteer-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 2px solid white;
  margin-left: -8px;
}

.volunteer-avatar:first-child {
  margin-left: 0;
}

.timeline {
  position: relative;
  padding-left: 2rem;
  margin: 1rem 0;
}

.timeline-item {
  position: relative;
  padding-bottom: 1.5rem;
  border-left: 2px solid var(--gray-200);
  padding-left: 1.5rem;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: -8px;
  top: 0;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--primary);
  border: 2px solid white;
}

/* Profile Page Styles */
.profile-page {
  background: var(--gray-50);
}

.profile-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2rem 3rem;
}

.profile-header {
  background: #FFFFFF;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  margin-bottom: 2rem;
  box-shadow: var(--shadow-sm);
}

.cover-photo {
  position: relative;
  height: 250px;
  overflow: hidden;
}

.cover-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.edit-cover-btn {
  position: absolute;
  bottom: 1rem;
  right: 1rem;
  background: rgba(0, 0, 0, 0.7);
  color: white;
  border: none;
  padding: 0.5rem 1rem;
  border-radius: 9999px;
  cursor: pointer;
  font-size: 0.875rem;
  backdrop-filter: blur(4px);
  transition: all 0.2s;
}

.edit-cover-btn:hover {
  background: black;
}

.profile-info-wrapper {
  display: flex;
  padding: 0 2rem 2rem;
  margin-top: -60px;
  position: relative;
  gap: 2rem;
  flex-wrap: wrap;
}

.profile-avatar-large {
  position: relative;
}

.profile-avatar-large img {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  border: 4px solid white;
  box-shadow: var(--shadow-lg);
  object-fit: cover;
}

.edit-avatar-btn {
  position: absolute;
  bottom: 5px;
  right: 5px;
  background: var(--primary);
  color: white;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.edit-avatar-btn:hover {
  background: var(--primary-dark);
  transform: scale(1.05);
}

.profile-details {
  flex: 1;
}

.profile-details h1 {
  font-size: 1.875rem;
  margin-bottom: 0.5rem;
}

.profile-badges {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}

.badge {
  padding: 0.25rem 0.75rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 500;
}

.badge.verified {
  background: rgba(76, 175, 80, 0.1);
  color: var(--primary);
}

.badge.donor {
  background: rgba(76, 175, 80, 0.1);
  color: var(--primary);
}

.badge.volunteer {
  background: rgba(30, 58, 138, 0.1);
  color: var(--secondary);
}

.profile-meta {
  display: flex;
  gap: 1.5rem;
  margin-bottom: 1rem;
  font-size: 0.875rem;
  color: var(--gray-500);
  flex-wrap: wrap;
}

.profile-meta i {
  margin-right: 0.25rem;
}

.profile-bio {
  color: var(--gray-600);
  margin-bottom: 1.5rem;
  line-height: 1.5;
}

.profile-actions {
  display: flex;
  gap: 1rem;
}

/* Profile Tabs */
.profile-tabs, .org-tabs {
  display: flex;
  gap: 0.5rem;
  border-bottom: 1px solid var(--gray-200);
  margin-bottom: 2rem;
  flex-wrap: wrap;
}

.tab-btn {
  padding: 0.75rem 1.5rem;
  background: none;
  border: none;
  font-weight: 500;
  color: var(--gray-500);
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
}

.tab-btn:hover {
  color: var(--primary);
}

.tab-btn.active {
  color: var(--primary);
}

.tab-btn.active::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--primary);
}

/* Stats Grid Profile */
.stats-grid-profile {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.stat-card-profile {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  border: 1px solid var(--gray-200);
  transition: all 0.2s;
}

.stat-card-profile:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.stat-card-profile .stat-icon {
  width: 56px;
  height: 56px;
  background: rgba(76, 175, 80, 0.1);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  color: var(--primary);
}

.stat-info {
  flex: 1;
}

.stat-info .stat-value {
  font-size: 1.5rem;
  font-weight: 700;
  display: block;
}

.stat-info .stat-label {
  font-size: 0.875rem;
  color: var(--gray-500);
}

/* Activity Feed */
.activity-feed, .impact-highlights {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  margin-bottom: 2rem;
  border: 1px solid var(--gray-200);
}

.activity-feed h3, .impact-highlights h3 {
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.feed-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.feed-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.75rem;
  border-radius: var(--radius-lg);
  background: var(--gray-50);
}

.feed-icon {
  width: 40px;
  height: 40px;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
}

/* Impact Grid */
.impact-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}

.impact-card {
  text-align: center;
  padding: 1rem;
  background: #f9fafb45;
  border-radius: var(--radius-lg);
  transition: all 0.2s;
}

.impact-card:hover {
  transform: translateY(-2px);
  background: var(--gray-100);
}

.impact-card i {
  font-size: 2rem;
  color: var(--primary);
  margin-bottom: 0.5rem;
}

.impact-card .impact-number {
  display: block;
  font-size: 1.5rem;
  font-weight: 700;
}

.impact-card .impact-label {
  font-size: 0.875rem;
  color: var(--gray-500);
}

/* Donations Table */
.donations-list, .volunteer-history, .supported-campaigns {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  border: 1px solid var(--gray-200);
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
  gap: 1rem;
}

.donations-table {
  overflow-x: auto;
}

.donations-table table {
  width: 100%;
  border-collapse: collapse;
}

.donations-table th {
  text-align: left;
  padding: 0.75rem;
  background: var(--gray-50);
  font-weight: 600;
  font-size: 0.875rem;
}

.donations-table td {
  padding: 0.75rem;
  border-bottom: 1px solid var(--gray-100);
  font-size: 0.875rem;
}

/* Settings Form */
.settings-container, .org-settings {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  border: 1px solid var(--gray-200);
}

.settings-form h3 {
  margin: 1.5rem 0 1rem;
  font-size: 1.125rem;
}

.settings-form h3:first-child {
  margin-top: 0;
}

.checkbox-group, .radio-group {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.checkbox-group label, .radio-group label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
}

/* Organization Page Styles */
.org-page {
  background: var(--gray-50);
}

.org-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2rem 3rem;
}

.org-header {
  background: #FFFFFF;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  margin-bottom: 2rem;
}

.org-banner {
  height: 200px;
  overflow: hidden;
}

.org-banner img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.org-info-wrapper {
  display: flex;
  padding: 0 2rem 2rem;
  margin-top: -50px;
  gap: 2rem;
  flex-wrap: wrap;
}

.org-logo img {
  width: 100px;
  height: 100px;
  border-radius: var(--radius-xl);
  border: 4px solid white;
  box-shadow: var(--shadow-lg);
  object-fit: cover;
}

.org-details {
  flex: 1;
}

.org-details h1 {
  font-size: 1.875rem;
  margin-bottom: 0.5rem;
}

.org-rating {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
  color: #fbbf24;
}

.org-rating span {
  color: var(--gray-500);
  font-size: 0.875rem;
}

.org-meta {
  display: flex;
  gap: 1.5rem;
  margin-bottom: 1rem;
  font-size: 0.875rem;
  color: var(--gray-500);
  flex-wrap: wrap;
}

.org-actions {
  display: flex;
  gap: 1rem;
  margin-top: 1rem;
}

/* Organization Campaigns Grid */
.org-campaigns-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
  gap: 1.5rem;
  margin-top: 1.5rem;
}

.org-campaign-card {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 1px solid var(--gray-200);
  transition: all 0.2s;
}

.org-campaign-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.org-campaign-image {
  height: 180px;
  background-size: cover;
  background-position: center;
  position: relative;
}

.campaign-status {
  position: absolute;
  top: 1rem;
  right: 1rem;
  padding: 0.25rem 0.75rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 600;
}

.status-active {
  background: rgba(76, 175, 80, 0.9);
  color: white;
}

.status-completed {
  background: rgba(30, 58, 138, 0.9);
  color: white;
}

.status-draft {
  background: rgba(100, 116, 139, 0.9);
  color: white;
}

.org-campaign-content {
  padding: 1rem;
}

.org-campaign-title {
  font-size: 1.125rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.org-campaign-stats {
  display: flex;
  justify-content: space-between;
  margin: 0.75rem 0;
  font-size: 0.875rem;
}

.org-campaign-actions {
  display: flex;
  gap: 0.5rem;
  margin-top: 1rem;
}

.campaigns-filters {
  display: flex;
  gap: 1rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.search-box-small {
  flex: 1;
  position: relative;
  min-width: 200px;
}

.search-box-small i {
  position: absolute;
  left: 1rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--gray-400);
}

.search-box-small input {
  width: 100%;
  padding: 0.625rem 1rem 0.625rem 2.5rem;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
}

/* Analytics Dashboard */
.analytics-dashboard {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  border: 1px solid var(--gray-200);
}

.analytics-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.analytics-card {
  text-align: center;
  padding: 1rem;
  background: var(--gray-50);
  border-radius: var(--radius-lg);
}

.analytics-card h4 {
  font-size: 0.875rem;
  color: var(--gray-500);
  margin-bottom: 0.5rem;
}

.analytics-value {
  font-size: 1.875rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.trend {
  font-size: 0.75rem;
}

.trend.up {
  color: var(--primary);
}

.chart-container {
  margin-bottom: 2rem;
}

.chart-container h3 {
  margin-bottom: 1rem;
}

.chart-bars-large {
  display: flex;
  align-items: flex-end;
  gap: 2rem;
  height: 250px;
  padding: 1rem;
  background: var(--gray-50);
  border-radius: var(--radius-lg);
}

/* Team Grid */
.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
  margin-top: 1.5rem;
}

.team-card {
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  text-align: center;
  border: 1px solid var(--gray-200);
  transition: all 0.2s;
}

.team-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.team-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  margin: 0 auto 1rem;
  object-fit: cover;
}

.team-name {
  font-weight: 700;
  margin-bottom: 0.25rem;
}

.team-role {
  font-size: 0.875rem;
  color: var(--gray-500);
  margin-bottom: 0.75rem;
}

.team-email {
  font-size: 0.75rem;
  color: var(--gray-400);
}

/* Supporters Grid */
.supporters-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 1rem;
  margin-top: 1.5rem;
}

.supporter-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem;
  background: var(--gray-50);
  border-radius: var(--radius-lg);
  transition: all 0.2s;
}

.supporter-card:hover {
  background: var(--gray-100);
}

.supporter-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
}

.supporter-info {
  flex: 1;
}

.supporter-name {
  font-weight: 600;
  font-size: 0.875rem;
}

.supporter-amount {
  font-size: 0.75rem;
  color: var(--primary);
  font-weight: 600;
}

/* Modal Large */
.modal-large {
  max-width: 600px;
}

.btn-danger {
  background: var(--cta);
  color: white;
  padding: 0.625rem 1.25rem;
  border-radius: 9999px;
  border: none;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-danger:hover {
  background: var(--cta-dark);
}

/* User Avatar Small */
.user-avatar-small {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  object-fit: cover;
}

.user-menu-dropdown {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
  padding: 0.25rem 0.5rem;
  border-radius: 9999px;
  transition: background 0.2s;
}

.user-menu-dropdown:hover {
  background: var(--gray-100);
}

/* Responsive Additions */
@media (max-width: 768px) {
  .profile-info-wrapper {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  
  .profile-meta {
    justify-content: center;
  }
  
  .profile-actions {
    justify-content: center;
  }
  
  .org-info-wrapper {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  
  .org-meta {
    justify-content: center;
  }
  
  .org-actions {
    justify-content: center;
  }
  
  .stats-grid-profile {
    grid-template-columns: 1fr;
  }
  
  .analytics-stats {
    grid-template-columns: 1fr;
  }
  
  .team-grid {
    grid-template-columns: 1fr;
  }
  
  .progress-step .step-label {
    font-size: 0.75rem;
  }
  
  .progress-line {
    width: 40px;
  }
}