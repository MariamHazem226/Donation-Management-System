// Initialize Profile Page
function initProfilePage() {
  if (!document.querySelector('.profile-container')) return;
  
  renderRecentActivity();
  renderDonationHistory();
  renderVolunteerHistory();
  renderSupportedCampaigns();
  setupProfileTabs();
  
  const settingsForm = document.getElementById('profileSettingsForm');
  if (settingsForm) {
    settingsForm.addEventListener('submit', (e) => {
      e.preventDefault();
      showToast('Profile updated successfully!');
    });
  }
}

function renderRecentActivity() {
  const container = document.getElementById('recentActivity');
  if (!container) return;
  
  container.innerHTML = recentActivities.map(activity => `
    <div class="feed-item">
      <div class="feed-icon"><i class="fas ${activity.icon}"></i></div>
      <div class="feed-content">
        <div class="feed-text">${activity.text}</div>
        <div class="feed-time">${activity.time}</div>
      </div>
    </div>
  `).join('');
}

function renderDonationHistory() {
  const container = document.getElementById('donationsTable');
  if (!container) return;
  
  container.innerHTML = `
    <table>
      <thead>
        <tr><th>Campaign</th><th>Amount</th><th>Date</th><th>Status</th></tr>
      </thead>
      <tbody>
        ${donationHistory.map(d => `
          <tr>
            <td>${d.campaign}</td>
            <td><strong>$${d.amount}</strong></td>
            <td>${d.date}</td>
            <td><span class="status-badge approved">${d.status}</span></td>
          </tr>
        `).join('')}
      </tbody>
    </table>
  `;
}

function renderVolunteerHistory() {
  const container = document.getElementById('volunteerHistoryList');
  if (!container) return;
  
  container.innerHTML = volunteerHistory.map(v => `
    <div class="volunteer-card" style="background: var(--gray-50); padding: 1rem; border-radius: var(--radius-lg); margin-bottom: 1rem;">
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
          <strong>${v.campaign}</strong>
          <div style="font-size: 0.875rem; color: var(--gray-500);">Role: ${v.role}</div>
        </div>
        <div style="text-align: right;">
          <div><strong>${v.hours} hours</strong></div>
          <div style="font-size: 0.75rem; color: var(--gray-400);">${v.date}</div>
        </div>
      </div>
    </div>
  `).join('');
}

function renderSupportedCampaigns() {
  const container = document.getElementById('supportedCampaignsList');
  if (!container) return;
  
  container.innerHTML = supportedCampaigns.map(c => `
    <div class="campaign-support-item" style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; border-bottom: 1px solid var(--gray-100);">
      <div>
        <strong>${c.title}</strong>
        <div style="font-size: 0.875rem; color: var(--gray-500);">Donated: $${c.donated}</div>
      </div>
      <span class="status-badge ${c.status === 'Active' ? 'approved' : ''}">${c.status}</span>
    </div>
  `).join('');
}

function setupProfileTabs() {
  const tabBtns = document.querySelectorAll('.profile-tabs .tab-btn');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tabId = btn.dataset.tab;
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      document.querySelectorAll('.profile-container .tab-content').forEach(tab => {
        tab.classList.remove('active');
      });
      
      const activeTab = document.getElementById(`${tabId}Tab`);
      if (activeTab) activeTab.classList.add('active');
    });
  });
}

// ========== ORGANIZATION PAGE FUNCTIONS ==========

// Organization Campaigns
let orgCampaigns = [
  { id: 1, title: 'Build a School in Kenya', category: 'Education', goal: 150000, current: 89200, status: 'active', image: 'https://images.unsplash.com/photo-1509062522246-3755977927d7?w=400', created: '2024-01-15' },
  { id: 2, title: 'Teacher Training Program', category: 'Education', goal: 75000, current: 45000, status: 'active', image: 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=400', created: '2024-02-01' },
  { id: 3, title: 'Scholarship Fund 2024', category: 'Education', goal: 200000, current: 200000, status: 'completed', image: 'https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=400', created: '2023-06-01' }
];

// Team Members
const teamMembers = [
  { name: 'Dr. James Mwangi', role: 'Executive Director', email: 'james@educationafrica.org', avatar: 'https://randomuser.me/api/portraits/men/32.jpg' },
  { name: 'Sarah Johnson', role: 'Program Manager', email: 'sarah@educationafrica.org', avatar: 'https://randomuser.me/api/portraits/women/68.jpg' },
  { name: 'David Ochieng', role: 'Field Coordinator', email: 'david@educationafrica.org', avatar: 'https://randomuser.me/api/portraits/men/45.jpg' }
];

// Top Supporters
const topSupporters = [
  { name: 'Emma Watson', amount: 5000, avatar: 'https://randomuser.me/api/portraits/women/1.jpg' },
  { name: 'Bill Gates', amount: 25000, avatar: 'https://randomuser.me/api/portraits/men/2.jpg' },
  { name: 'Oprah Winfrey', amount: 15000, avatar: 'https://randomuser.me/api/portraits/women/3.jpg' }
];

function initOrganizationPage() {
  if (!document.querySelector('.org-container')) return;
  
  renderOrgCampaigns();
  renderTeamMembers();
  renderSupporters();
  renderTopPerformingCampaigns();
  renderOrgDonationChart();
  setupOrgTabs();
  setupOrgFilters();
  
  const settingsForm = document.getElementById('orgSettingsForm');
  if (settingsForm) {
    settingsForm.addEventListener('submit', (e) => {
      e.preventDefault();
      showToast('Organization settings saved!');
    });
  }
}

function renderOrgCampaigns(filter = 'all', search = '') {
  const container = document.getElementById('orgCampaignsList');
  if (!container) return;
  
  let filtered = orgCampaigns.filter(c => filter === 'all' || c.status === filter);
  if (search) {
    filtered = filtered.filter(c => c.title.toLowerCase().includes(search.toLowerCase()));
  }
  
  container.innerHTML = filtered.map(campaign => `
    <div class="org-campaign-card">
      <div class="org-campaign-image" style="background-image: url('${campaign.image}')">
        <span class="campaign-status status-${campaign.status}">${campaign.status.toUpperCase()}</span>
      </div>
      <div class="org-campaign-content">
        <h4 class="org-campaign-title">${campaign.title}</h4>
        <div class="progress-section">
          <div class="progress-bar">
            <div class="progress-fill" style="width: ${(campaign.current / campaign.goal) * 100}%"></div>
          </div>
          <div class="campaign-stats">
            <span>$${campaign.current.toLocaleString()} raised</span>
            <span>of $${campaign.goal.toLocaleString()}</span>
          </div>
        </div>
        <div class="org-campaign-actions">
          <button class="btn-secondary btn-sm" onclick="editOrgCampaign(${campaign.id})">Edit</button>
          <button class="btn-outline btn-sm" onclick="viewCampaign(${campaign.id})">View</button>
        </div>
      </div>
    </div>
  `).join('');
}

function setupOrgFilters() {
  const searchInput = document.getElementById('orgCampaignSearch');
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const filter = document.getElementById('campaignStatusFilter')?.value || 'all';
      renderOrgCampaigns(filter, e.target.value);
    });
  }
  
  const statusFilter = document.getElementById('campaignStatusFilter');
  if (statusFilter) {
    statusFilter.addEventListener('change', (e) => {
      const search = document.getElementById('orgCampaignSearch')?.value || '';
      renderOrgCampaigns(e.target.value, search);
    });
  }
}

function renderTeamMembers() {
  const container = document.getElementById('teamMembersList');
  if (!container) return;
  
  container.innerHTML = teamMembers.map(member => `
    <div class="team-card">
      <img src="${member.avatar}" alt="${member.name}" class="team-avatar">
      <h4 class="team-name">${member.name}</h4>
      <div class="team-role">${member.role}</div>
      <div class="team-email">${member.email}</div>
    </div>
  `).join('');
}

function renderSupporters() {
  const container = document.getElementById('supportersList');
  if (!container) return;
  
  container.innerHTML = topSupporters.map(supporter => `
    <div class="supporter-card">
      <img src="${supporter.avatar}" alt="${supporter.name}" class="supporter-avatar">
      <div class="supporter-info">
        <div class="supporter-name">${supporter.name}</div>
        <div class="supporter-amount">$${supporter.amount.toLocaleString()}</div>
      </div>
    </div>
  `).join('');
}

function renderTopPerformingCampaigns() {
  const container = document.getElementById('topPerformingCampaigns');
  if (!container) return;
  
  const topCampaigns = [...orgCampaigns].sort((a, b) => b.current - a.current);
  container.innerHTML = topCampaigns.map(c => `
    <div class="top-campaign-item">
      <div class="campaign-info">
        <h4>${c.title}</h4>
        <span>${Math.round((c.current / c.goal) * 100)}% funded</span>
      </div>
      <div class="campaign-amount">$${c.current.toLocaleString()}</div>
    </div>
  `).join('');
}

function renderOrgDonationChart() {
  const container = document.getElementById('orgDonationChart');
  if (!container) return;
  
  const monthlyData = [45, 62, 78, 92, 108, 145];
  const months = ['Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  
  container.innerHTML = monthlyData.map((value, index) => `
    <div class="bar-container" style="flex: 1;">
      <div class="bar" style="height: ${value}px; background: linear-gradient(180deg, var(--primary), var(--secondary));"></div>
      <span class="bar-label">${months[index]}</span>
    </div>
  `).join('');
}

function setupOrgTabs() {
  const tabBtns = document.querySelectorAll('.org-tabs .tab-btn');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tabId = btn.dataset.tab;
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      document.querySelectorAll('.org-container .tab-content').forEach(tab => {
        tab.classList.remove('active');
      });
      
      const activeTab = document.getElementById(`${tabId}Tab`);
      if (activeTab) activeTab.classList.add('active');
    });
  });
}

function createNewCampaign() {
  const modal = document.getElementById('createCampaignModal');
  if (modal) modal.style.display = 'flex';
}

function editOrgCampaign(campaignId) {
  const campaign = orgCampaigns.find(c => c.id === campaignId);
  if (!campaign) return;
  
  document.getElementById('editCampaignId').value = campaign.id;
  document.getElementById('editCampaignTitle').value = campaign.title;
  document.getElementById('editCampaignCategory').value = campaign.category;
  document.getElementById('editCampaignDescription').value = campaign.description || '';
  document.getElementById('editCampaignGoal').value = campaign.goal;
  
  const modal = document.getElementById('editCampaignModal');
  if (modal) modal.style.display = 'flex';
}

function deleteCampaign() {
  const id = document.getElementById('editCampaignId').value;
  if (confirm('Are you sure you want to delete this campaign?')) {
    orgCampaigns = orgCampaigns.filter(c => c.id !== parseInt(id));
    renderOrgCampaigns();
    closeModal('editCampaignModal');
    showToast('Campaign deleted successfully');
  }
}

function inviteTeamMember() {
  showToast('Invitation sent! (Demo)');
}

function editProfile() {
  showToast('Profile edit mode (Demo)');
}

function shareProfile() {
  showToast('Profile link copied to clipboard!');
}

function editOrganization() {
  showToast('Organization settings opened');
}

// New Campaign Form Submission
const newCampaignForm = document.getElementById('newCampaignForm');
if (newCampaignForm) {
  newCampaignForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const newCampaign = {
      id: orgCampaigns.length + 1,
      title: document.getElementById('campaignTitle').value,
      category: document.getElementById('campaignCategory').value,
      goal: parseInt(document.getElementById('campaignGoal').value),
      current: 0,
      status: 'draft',
      image: document.getElementById('campaignImage').value || 'https://images.unsplash.com/photo-1509062522246-3755977927d7?w=400',
      created: new Date().toISOString().split('T')[0]
    };
    orgCampaigns.push(newCampaign);
    renderOrgCampaigns();
    closeModal('createCampaignModal');
    showToast('Campaign created successfully!');
    newCampaignForm.reset();
  });
}

// Edit Campaign Form Submission
const editCampaignForm = document.getElementById('editCampaignForm');
if (editCampaignForm) {
  editCampaignForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const id = parseInt(document.getElementById('editCampaignId').value);
    const index = orgCampaigns.findIndex(c => c.id === id);
    if (index !== -1) {
      orgCampaigns[index] = {
        ...orgCampaigns[index],
        title: document.getElementById('editCampaignTitle').value,
        category: document.getElementById('editCampaignCategory').value,
        goal: parseInt(document.getElementById('editCampaignGoal').value)
      };
      renderOrgCampaigns();
      closeModal('editCampaignModal');
      showToast('Campaign updated successfully!');
    }
  });
}

// Initialize all new pages
document.addEventListener('DOMContentLoaded', () => {
  initProfilePage();
  initOrganizationPage();
});